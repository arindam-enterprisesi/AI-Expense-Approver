# Google APIs Configuration
# Get these values from Google Cloud Console

# Gmail OAuth 2.0 Client ID
# Created at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# Gmail OAuth 2.0 Client Secret
# Created at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_SECRET=your_client_secret_here

# Google Gemini API Key
# Created at: https://console.cloud.google.com/apis/credentials
# Used for AI proposal analysis
VITE_GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Configure these for production
# VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_ENVIRONMENT=production
